use std.io

type Option[T] =
    | None
    | Some(T)

safe_div(x: Int, y: Int) -> Option[Int] =
    match y == 0 {
        | True -> None
        | False -> Some(x / y)
    }

let main() -> Nil =
    match safe_div(10, 2) {
        | None -> io.eprintln("Division by zero")
        | Some(v) -> io.println(v)
    }